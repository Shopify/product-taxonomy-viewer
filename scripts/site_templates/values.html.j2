{% extends "base.html.j2" %}
{% block body %}
{% include "_header.html.j2" %}
<div class="value-search-wrapper">
  <div class="search-container">
    <label for="value-search" class="search-container__label">Value search:</label>
    <input class="search-container__input" type="text" id="value-search" placeholder="Loading…">
    <ul class="search-container__ul" id="value-search-results"></ul>
  </div>
</div>
{% for value in values %}
<div class="value-page-entry hidden" data-handle="{{ value.handle }}">
  <div class="column">
    <div class="value-wrapper box">
      <div class="value-container value-detail">
        <h3>{{ value.name }}</h3>
        <div class="value-container__id">
          <span class="id">{{ value.id }}</span>
          <span class="id">{{ value.handle }}</span>
        </div>
      </div>
    </div>
  </div>
  <div class="column">
    <div class="value-attribute-wrapper box">
      <div class="value-container value-attribute">
        <h3>Attribute</h3>
        <p>
          <a href="{{ release_prefix }}attributes/?attributeHandle={{ value.attribute_handle }}">
            {{ value.attribute_name }}
          </a>
        </p>
      </div>
    </div>
  </div>
</div>
{% endfor %}
<script type="module" src="{{ assets_prefix }}assets/js/value_release.js"></script>
{% endblock %}
