{% extends "base.html.j2" %}
{% block body %}
<div class="header-container container">
  <h1>Shopify Internal Product Taxonomy</h1>
  <p>
    Interactive viewer for the in-development Shopify product taxonomy maintained in the
    <a href="https://github.com/Shopify/product-taxonomy-internal">product-taxonomy-internal</a>
    repo. The data shown here is the next, unreleased version &mdash; structure and naming may
    still change before it ships publicly.
  </p>
  <ul class="header-links">
    <li class="header-links__li header-links__li--first-child">
      <a href="https://github.com/Shopify/product-taxonomy-internal">GitHub</a>
    </li>
    <li class="header-links__li">
      <a href="https://shopify.github.io/product-taxonomy/releases/unstable/" target="_blank">
        Public viewer
      </a>
    </li>
  </ul>
</div>
<div class="content-container">
  <div class="column">
    <h2>Releases</h2>
    <ul>
      {% for release in releases %}
      <li>
        <a href="{{ release.path }}">Explore {{ release.title }}</a>
        (sourced from <a href="{{ release.github_url }}" target="_blank">GitHub</a>)
      </li>
      {% endfor %}
    </ul>
  </div>
</div>
{% endblock %}
